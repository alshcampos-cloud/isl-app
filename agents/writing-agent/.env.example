# IAI Writing Agent — environment variables
# Copy this file to .env and fill in values. Never commit .env.

# Required for all modes
ANTHROPIC_API_KEY=sk-ant-...

# Required for --db mode (save draft to Supabase via blog-publish endpoint)
BLOG_PUBLISH_URL=https://interviewanswers.ai/api/blog-publish
BLOG_AGENT_SECRET=your-shared-secret-here

# Required for email notifications when a draft is saved
RESEND_API_KEY=re_...
