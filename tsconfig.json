{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@agents/*": ["agents/*"]
    }
  },
  "include": ["agents/**/*.ts", "api/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
